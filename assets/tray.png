<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0a2e"/>
      <stop offset="100%" style="stop-color:#0d0618"/>
    </linearGradient>
    <linearGradient id="nGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#c084fc"/>
      <stop offset="50%" style="stop-color:#a855f7"/>
      <stop offset="100%" style="stop-color:#7c3aed"/>
    </linearGradient>
    <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e9d5ff;stop-opacity:0.15"/>
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:0"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="softGlow">
      <feGaussianBlur stdDeviation="12" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <clipPath id="roundClip">
      <rect width="256" height="256" rx="52" ry="52"/>
    </clipPath>
  </defs>

  <!-- Background -->
  <rect width="256" height="256" rx="52" ry="52" fill="url(#bgGrad)"/>

  <!-- Subtle inner glow overlay -->
  <rect width="256" height="256" rx="52" ry="52" fill="url(#glowGrad)"/>

  <!-- Very subtle grid lines for depth -->
  <g clip-path="url(#roundClip)" opacity="0.04">
    <line x1="0" y1="64" x2="256" y2="64" stroke="#a855f7" stroke-width="1"/>
    <line x1="0" y1="128" x2="256" y2="128" stroke="#a855f7" stroke-width="1"/>
    <line x1="0" y1="192" x2="256" y2="192" stroke="#a855f7" stroke-width="1"/>
    <line x1="64" y1="0" x2="64" y2="256" stroke="#a855f7" stroke-width="1"/>
    <line x1="128" y1="0" x2="128" y2="256" stroke="#a855f7" stroke-width="1"/>
    <line x1="192" y1="0" x2="192" y2="256" stroke="#a855f7" stroke-width="1"/>
  </g>

  <!-- Glow behind the N -->
  <ellipse cx="128" cy="128" rx="72" ry="72" fill="#7c3aed" opacity="0.12" filter="url(#softGlow)"/>

  <!-- The N — clean geometric, slightly condensed -->
  <g filter="url(#glow)">
    <path d="
      M 72 68
      L 72 188
      L 96 188
      L 96 113
      L 160 188
      L 184 188
      L 184 68
      L 160 68
      L 160 143
      L 96 68
      Z
    " fill="url(#nGrad)" stroke="#e9d5ff" stroke-width="1.5" stroke-opacity="0.3" stroke-linejoin="round"/>
  </g>

  <!-- Top-left corner accent dot -->
  <circle cx="72" cy="68" r="3.5" fill="#c084fc" opacity="0.8"/>
  <!-- Bottom-right corner accent dot -->
  <circle cx="184" cy="188" r="3.5" fill="#7c3aed" opacity="0.8"/>

  <!-- Thin border -->
  <rect width="256" height="256" rx="52" ry="52" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-opacity="0.25"/>
</svg>
